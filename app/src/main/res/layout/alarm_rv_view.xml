<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="15dp"
    android:elevation="8dp"
    android:background="@drawable/border_soft_white"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_margin="15dp"
        android:id="@+id/ic_item"
        android:layout_width="60dp"
        android:layout_height="60dp"/>
    <TextView
        android:id="@+id/textNameTitle"
        android:textColor="@color/text"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Medicine Name"
        android:layout_margin="15dp"
        android:textSize="20dp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/ic_item"
        app:layout_constraintTop_toTopOf="@id/ic_item"
        app:layout_constraintStart_toEndOf="@id/ic_item"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:textColor="@color/secondaryText"
        android:layout_width="0dp"
        app:layout_constraintStart_toEndOf="@id/ic_item"
        app:layout_constraintTop_toBottomOf="@id/textNameTitle"
        android:text="Lorem"
        android:id="@+id/note_text"
        android:textStyle="italic"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="15dp"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/timeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="15dp"
        android:text="10.15"
        android:textColor="@color/secondaryText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="15dp"
        android:text="Aldım"
        android:id="@+id/confirm_btn"/>






</androidx.constraintlayout.widget.ConstraintLayout>