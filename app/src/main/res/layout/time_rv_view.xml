<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="200dp"
    android:layout_margin="15dp"
    android:elevation="8dp"
    android:background="@drawable/border_soft_white"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/buttons_layout"
        app:layout_constraintHorizontal_weight="0.80"
        android:padding="10dp"
        android:id="@+id/titles_layout"
        android:layout_weight="16"
        android:layout_width="0dp"
        android:orientation="vertical"
        android:layout_height="match_parent">


        <TextView
            android:id="@+id/medicine_time"
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:text="10.15"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/medicine_dose"
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:text="100mg"
            android:layout_height="wrap_content"/>
        <TextView
            android:id="@+id/med_usage_note"
            android:layout_weight="4"
            android:layout_width="wrap_content"
            android:text="Kullanıcı notu:"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <LinearLayout app:layout_constraintStart_toEndOf="@id/titles_layout"
        app:layout_constraintHorizontal_weight="0.20"

        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:layout_weight="4"
        android:gravity="center"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:id="@+id/buttons_layout">
        <ImageView
            android:id="@+id/edit_med_time"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@color/black"/>
        <ImageView
            android:id="@+id/delete_med_time"
            android:layout_marginTop="20dp"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:background="@color/black"/>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>